# ---------------------------------------------------------------------------
# Copy this file to `.env` and adjust values as needed.
# ---------------------------------------------------------------------------

# General
PROJECT_NAME=Notes Management API
ENVIRONMENT=local
DEBUG=true
API_V1_PREFIX=/api/v1

# Security
SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS (comma-separated list of allowed origins)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=notes_db
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
# Optional full override (takes precedence over the POSTGRES_* parts above):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/notes_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# Optional full override:
# REDIS_URL=redis://redis:6379/0

# File uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=5242880

# Cache TTLs (seconds)
CACHE_TTL_NOTES_LIST=60
CACHE_TTL_SEARCH=30
CACHE_TTL_USER_PROFILE=300

# Rate limiting
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_LOGIN_WINDOW=60
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_REGISTER_WINDOW=60
LOG_DIR=logs
LOG_FILE=app.log
